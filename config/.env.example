# Скопируйте в config/.env и заполните реальными значениями.
# Файл config/.env в .gitignore — не коммитить!

# Путь к settings.yaml (относительно корня проекта)
SETTINGS_PATH=config/settings.yaml

# Max Bot API — токен бота (заголовок Authorization)
MAX_TOKEN=your_max_bot_token_here
# Секрет webhook (заголовок X-Max-Bot-Api-Secret, POST /subscriptions)
MAX_WEBHOOK_SECRET=
# Публичный HTTPS URL (порт 443), переопределяет max_bot.webhook_url в settings.yaml
MAX_WEBHOOK_URL=

# Google Sheets — сервисный аккаунт (JSON вне репозитория, не коммитить)
# См. docs/Памятка_Google_SA_ключ.md
# Windows: GOOGLE_SA_JSON_PATH=C:/secrets/1apart-sheets-sa.json
# VPS:     GOOGLE_SA_JSON_PATH=/etc/1apart/service_account.json
# Docker:  GOOGLE_SA_JSON_PATH=config/service_account.json
GOOGLE_SA_JSON_PATH=

# TravelLine API — ключ из ЛК (Bearer) или OAuth client credentials
TL_API_KEY=your_travelline_api_key_here
# TL_CLIENT_ID=
# TL_CLIENT_SECRET=

# SMTP — Яндекс (еженедельный email-отчёт)
# docs/Настройка_SMTP_Yandex.md
# Вариант A (рекомендуется): 587 + STARTTLS
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# Вариант B: 465 + SSL
# SMTP_PORT=465
# SMTP_USE_TLS=false
# SMTP_USE_SSL=true
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=bogdanchik2@yandex.ru
SMTP_PASSWORD=your_yandex_app_password_here
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# from_address в settings.yaml = SMTP_USER; dry_run → email.test_addresses

# Веб-админка
ADMIN_PASSWORD=change_me_in_production
# Альтернатива: токен вместо пароля (если задан — используется вместо пароля)
# ADMIN_TOKEN=

# Автодеплой на VPS (после задач планировщика / агента Cursor / CI)
DEPLOY_ENABLED=false
VPS_HOST=91.229.11.147
VPS_USER=root
VPS_APP_DIR=/opt/1apart/hotel-report-bot

# Секрет для сессий FastAPI
SECRET_KEY=generate_a_random_secret_key_here

# Опционально: LLM для обогащения карточек аналитики (без ключа — rule-based)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
WEB_FORCE_HTTPS=true
