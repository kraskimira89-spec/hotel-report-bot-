# Скопируйте в config/.env и заполните реальными значениями.
# Файл config/.env в .gitignore — не коммитить!

# Путь к settings.yaml (относительно корня проекта)
SETTINGS_PATH=config/settings.yaml

# Max Bot API — токен бота (заголовок Authorization)
MAX_TOKEN=your_max_bot_token_here

# Google Sheets — сервисный аккаунт (JSON вне репозитория)
GOOGLE_SA_JSON_PATH=/path/to/service_account.json

# TravelLine API
TL_API_KEY=your_travelline_api_key_here

# SMTP (еженедельный email-отчёт)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=reports@1apart.ru
SMTP_PASSWORD=your_smtp_password_here
SMTP_USE_TLS=true

# Веб-админка
ADMIN_PASSWORD=change_me_in_production
# Альтернатива: токен вместо пароля (если задан — используется вместо пароля)
# ADMIN_TOKEN=

# Секрет для сессий FastAPI
SECRET_KEY=generate_a_random_secret_key_here
